# But always ignore Obsidian's per-machine state:
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache/

# Local drafts (any folder starting with _ is ignored by the platform too)
_drafts/
_local/

# CLI cache
.studyme-cache/

